# URL del backend que consume el frontend (se lee en build/dev por Vite).
#
# - Backend local propio:        http://localhost:3000
# - Backend de un companero via
#   tunel Cloudflare:            https://algo-aleatorio.trycloudflare.com
#
# Copia este archivo a `.env` y ajusta el valor. Reinicia `npm run dev` tras cambiarlo.
VITE_API_URL=http://localhost:3000
